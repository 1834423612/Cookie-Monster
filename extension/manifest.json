{
  "manifest_version": 3,
  "name": "Cookie Monster",
  "version": "0.1.0",
  "description": "Analyze, export, clean, and restore browser cookies with privacy-first local tooling.",
  "key": "",
  "permissions": [
    "cookies",
    "storage",
    "downloads",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cookie Monster"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "dashboard.html",
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://127.0.0.1/*",
      "https://localhost/*",
      "https://cookie-monster.app/*",
      "https://www.cookie-monster.app/*",
      "https://cookie-monster.vercel.app/*"
    ]
  },
  "minimum_chrome_version": "116"
}
