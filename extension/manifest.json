{
  "manifest_version": 3,
  "name": "Cookie Monster",
  "version": "0.1.0",
  "description": "Analyze, export, clean, and restore browser cookies with privacy-first local tooling.",
  "key": "",
  "permissions": [
    "cookies",
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://localhost/*",
      "http://127.0.0.1/*",
      "https://127.0.0.1/*",
      "https://cookie-monster.makesome.cool/*",
      "https://*.makesome.cool/*",
      "https://*.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cookie Monster",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "page-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "dashboard.html",
  "minimum_chrome_version": "116"
}
